# Copy to .env and fill in. NEVER commit .env (this repo is public).

# --- Web ---
PORT=3000
DATABASE_PATH=./data/mealdeal.db

# --- Inbox the agent reads (a DEDICATED mailbox you sign newsletters up with) ---
# Gmail: create an App Password and use it here. Plus-address signups (you+merchant@gmail.com)
# so each deal's source is tagged.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=youraddress@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_MAILBOX=INBOX

# --- LLM endpoint used to extract deals from emails (any OpenAI-compatible API) ---
# Homelab: point at your local model. Others: OpenAI, Ollama (http://host:11434/v1), etc.
OPENAI_BASE_URL=http://llamacpp.lan:1234/v1
OPENAI_API_KEY=not-needed-for-local
OPENAI_MODEL=qwen3.6-35b-a3b

# --- Ingest scheduling ---
INGEST_CRON=0 7 * * *        # daily 7am (server local time)
INGEST_ON_START=false        # set true to run one ingest pass at startup (handy for testing)

# --- Optional: allow external pushes to POST /api/ingest (leave empty to disable) ---
INGEST_TOKEN=
