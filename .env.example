# Copy to .env and fill in. NEVER commit .env (this is a public repo).

# Database — SQLite by default (a libsql file: URL). For Postgres, see AGENTS.md.
DATABASE_URL=file:/data/mealdeal.db

# IMAP mailbox to ingest (bring your own inbox)
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# OpenAI-compatible LLM for extraction (bring your own — e.g. a local server)
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=
OPENAI_MODEL=qwen3.6-35b-a3b

# Ingest schedule (node-cron) + per-pass batch size
INGEST_CRON=*/30 * * * *
INGEST_BATCH=25
# INGEST_INLINE=0 disables the in-server scheduler (run `node dist/worker.js` separately)

# Optional bearer token guarding POST /internal/ingest (manual trigger)
INGEST_TOKEN=
