# Copy to .env and fill in. NEVER commit .env (this is a public repo).

# Database — SQLite by default (a libsql file: URL). For Postgres, see AGENTS.md.
DATABASE_URL=file:/data/mealdeal.db

# IMAP mailbox to ingest (bring your own inbox)
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# OpenAI-compatible LLM for extraction (bring your own — e.g. a local server)
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=
OPENAI_MODEL=qwen3.6-35b-a3b

# Ingest schedule (node-cron) + per-pass batch size
INGEST_CRON=*/30 * * * *
INGEST_BATCH=25
# INGEST_INLINE=0 disables the in-server scheduler (run `node dist/worker.js` separately)

# Email source: `imap` (default) reads the configured mailbox; `folder` replays top-level
# Markdown files from INGEST_LOCAL_DIR and moves acknowledged files to processed/.
INGEST_SOURCE=imap
INGEST_LOCAL_DIR=
# Optional local corpus archive for canonical Markdown from real IMAP messages only.
INGEST_ARCHIVE_DIR=

# Optional bearer token guarding POST /internal/ingest (manual trigger)
INGEST_TOKEN=
# `pnpm ingest` sends this token to the running server. Override its URL if needed.
# INGEST_SERVER_URL=http://localhost:4000/internal/ingest

# Optional five-digit US ZIP used by future near-me features (for example, 02139).
USER_LOCATION=
