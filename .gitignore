# deps / build
node_modules/
dist/
.turbo/
*.tsbuildinfo

# git worktrees — the autonomous coding loop creates per-task feature worktrees here
.worktrees/

# planner scratch (scope-and-plan writes PLAN.md + backlog.json here; not committed)
.plan/

# reviewer PR-description scratch (open-pr reads + deletes it; not committed)
.pr-body.md

# runtime data (SQLite lives here by default)
*.db
*.db-*
data/

# Private email archives / offline inboxes (commit only synthetic test fixtures).
ingest-archive/
ingest-input/

# env / secrets (public repo — never commit)
.env
.env.*
!.env.example

# test / coverage
coverage/

# editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json

# NOTE: generated-but-COMMITTED artifacts are intentionally NOT ignored
#   packages/contract/schema.graphql   (emitted from Pothos; drift-checked)
#   packages/web/src/graphql-env.d.ts   (gql.tada introspection; drift-checked)
