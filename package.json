{
  "name": "mealdeal",
  "version": "0.1.0",
  "description": "Track grocery coupons/sales from newsletters and (soon) turn them into weekly recipes. Self-hosted, bring-your-own inbox + LLM.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "start": "node src/index.ts",
    "dev": "node --watch src/index.ts",
    "ingest:once": "node src/ingest/run-once.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "express": "^5.1.0",
    "imapflow": "^1.0.191",
    "mailparser": "^3.7.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^24.0.0",
    "@types/node-cron": "^3.0.11",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.63.0"
  }
}
