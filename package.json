{
  "name": "mealdeal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Self-hosted grocery-deal ingester + web — a decoupled GraphQL API (Yoga + Pothos + Drizzle) and a Vite/React SPA, one container.",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"@mealdeal/*\" dev",
    "build": "pnpm build-schema && pnpm --filter @mealdeal/web gen && pnpm --filter @mealdeal/web build && pnpm --filter @mealdeal/api build",
    "build-schema": "pnpm --filter @mealdeal/api build-schema",
    "gen": "pnpm build-schema && pnpm --filter @mealdeal/web gen",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --if-present test",
    "check:drift": "node scripts/check-drift.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm check:drift",
    "db:generate": "pnpm --filter @mealdeal/api db:generate",
    "db:migrate": "pnpm --filter @mealdeal/api db:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^26.1.1",
    "eslint": "^9.39.5",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^7.0.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
